# Local development (backend/.env)
DATABASE_URL="file:./dev.db"
JWT_SECRET="local-dev-secret-change-before-production-min-32-chars"
JWT_EXPIRES_IN="24h"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Optional: override default dev admin password when running npm run db:seed
# SEED_ADMIN_PASSWORD=

# Production values go in backend/.env.production — see .env.production.example
