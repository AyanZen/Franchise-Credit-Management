# Production — copy to .env.production and set real values
# On Render, add these as environment variables (not from a file)

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
JWT_SECRET="use-a-long-random-secret-in-production"
PORT=3001
NODE_ENV=production
FRONTEND_URL="https://your-app.vercel.app"

# Email reminders (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Keep Render awake (optional, free tier sleeps after ~15 min idle):
# Use https://cron-job.org to GET every 10 minutes:
# https://YOUR-SERVICE.onrender.com/api/health
